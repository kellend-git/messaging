{
  "name": "@astropods/messaging",
  "license": "Apache-2.0",
  "version": "0.0.3",
  "description": "TypeScript SDK for Astro Messaging",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "postinstall": "rm -rf proto && ln -sf ../../proto proto",
    "build": "tsc && rm -rf dist/proto && cp -r ../../proto dist/proto",
    "watch": "tsc --watch",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/astropods/messaging.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.10"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}