{
  "name": "@astromode-ai/astro-messaging",
  "version": "0.1.1",
  "description": "TypeScript SDK for Astro Messaging",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "postinstall": "ln -sf ../../proto proto",
    "build": "tsc && cp -r ../../proto dist/proto",
    "watch": "tsc --watch",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/astromode-ai/astro-messaging.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.10"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
